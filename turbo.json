{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "PORT",
    "DATABASE_URL",
    "CLERK_SECRET_KEY",
    "FRONTEND_ORIGINS",
    "NEXT_PUBLIC_SVC_ROADMAP_URL",
    "NEXT_PUBLIC_SVC_API_URL",
    "SENTRY_DSN",
    "SENTRY_TRACES_SAMPLE_RATE",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_AUTH_TOKEN",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "ADMIN_URL",
        "SUPER_ADMIN_URL",
        "NEXT_PUBLIC_SVC_ROADMAP_URL",
        "NEXT_PUBLIC_SVC_API_URL",
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "FRONTEND_ORIGINS"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
