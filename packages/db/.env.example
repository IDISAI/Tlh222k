# =============================================================================
# packages/db - Prisma schema and client (@workspace/db)
# =============================================================================
# Usage:
#   cp packages/db/.env.example packages/db/.env
#
# Needed by Prisma CLI commands in this package: generate, db:push, seed.
# svc-roadmap has its own apps/svc-roadmap/.env; keep both DATABASE_URL values
# pointing at the same database.
# =============================================================================

# Dev: SQLite, zero external infrastructure.
# Resolves to packages/db/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Prod: use Postgres/Neon and prisma/schema.postgres.prisma.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"
