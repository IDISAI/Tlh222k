// PROD (Postgres) variant of schema.prisma, used only for deploys that run on
// Postgres — e.g. svc-roadmap on Vercel (SQLite can't run on serverless).
// Local dev still uses schema.prisma (SQLite, zero infra). Keep the two model
// blocks in sync; they are identical except the datasource + generator here.
//
//   - provider "postgresql" instead of "sqlite"
//   - binaryTargets so `prisma generate` emits the query engine for Vercel's
//     Linux runtime ("rhel-openssl-3.0.x") alongside the local "native" one.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Roadmap {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String?
  thumbnailUrl String?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nodes Node[]
}

model Node {
  id           String   @id @default(cuid())
  roadmapId    String
  parentId     String?
  title        String
  slug         String   @unique
  description  String?
  nodeType     String // role | skill | chapter | article
  notionPageId String?
  articleType  String? // notion | jupyter
  jupyterUrl   String?
  positionX    Float    @default(0)
  positionY    Float    @default(0)
  order        Int      @default(0)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roadmap  Roadmap        @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  parent   Node?          @relation("NodeChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children Node[]         @relation("NodeChildren")
  progress UserProgress[]

  @@index([roadmapId])
  @@index([parentId])
}

model UserProgress {
  clerkUserId String
  nodeId      String
  status      String   @default("locked") // locked | in_progress | done
  updatedAt   DateTime @updatedAt

  node Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // Composite PK → upsert(setNodeStatus) is idempotent per (user, node).
  @@id([clerkUserId, nodeId])
  @@index([nodeId])
}
