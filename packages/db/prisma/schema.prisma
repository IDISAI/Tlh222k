// Roadmap Platform DB — Postgres (Neon) for dev and prod. Dev runs on a Neon
// `dev` branch, prod on the default branch, same engine end to end. nodeType,
// articleType and status stay plain strings validated in the service layer
// (apps/svc-roadmap); promote to native enums later if desired.
//
//   - DATABASE_URL: pooled (-pooler host) — used at runtime (serverless-safe).
//   - DIRECT_URL:   direct (non-pooled)   — used by `prisma db push`/`migrate`.
//   - binaryTargets: emit the Vercel Linux query engine alongside native.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Roadmap {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String?
  thumbnailUrl String?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nodes       Node[]
  linkedNodes Node[] @relation("NodeLinkedRoadmap")
}

model Node {
  id              String   @id @default(cuid())
  roadmapId       String
  parentId        String?
  title           String
  slug            String   @unique
  description     String?
  nodeType        String // role | skill | chapter | article
  notionPageId    String?
  articleType     String? // notion | jupyter
  jupyterUrl      String?
  positionX       Float    @default(0)
  positionY       Float    @default(0)
  order           Int      @default(0)
  isDeleted       Boolean  @default(false)
  // Roadmap auto-created for role/skill nodes (notion-article-node Req 11).
  linkedRoadmapId String?
  // Publish state synced with the linked Document (notion-article-node Req 7).
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  roadmap       Roadmap        @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  parent        Node?          @relation("NodeChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children      Node[]         @relation("NodeChildren")
  linkedRoadmap Roadmap?       @relation("NodeLinkedRoadmap", fields: [linkedRoadmapId], references: [id], onDelete: SetNull)
  progress      UserProgress[]
  // Discovery labels. Many-to-many on purpose: a role like "Data Engineer"
  // belongs under both AI and Data, so it must surface under either tab.
  fields        Field[]

  @@index([roadmapId])
  @@index([parentId])
}

/// A discovery label ("Web Dev", "AI", "Data") shown as a tab on /roadmaps.
/// NOT a hierarchy level: a Field owns no canvas and is never navigable — it
/// only groups blocks. Admins create these inline from the node dialog, so the
/// tab strip is data-driven rather than a hardcoded list.
model Field {
  id        String   @id @default(cuid())
  /// Unique so the inline "create" path can't silently mint "AI" twice.
  name      String   @unique
  slug      String   @unique
  /// Display order in the tab strip; ties fall back to name.
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes Node[]
}

model RoadmapUpdateEvent {
  id        String   @id @default(cuid())
  roadmapId String
  createdAt DateTime @default(now())

  @@index([roadmapId, createdAt])
}

model UserProgress {
  clerkUserId String
  nodeId      String
  status      String   @default("locked") // locked | in_progress | done
  updatedAt   DateTime @updatedAt

  node Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // Composite PK → upsert(setNodeStatus) is idempotent per (user, node).
  @@id([clerkUserId, nodeId])
  @@index([nodeId])
}

// Notion-style hierarchical document (packages/core/src/notion). `slug` is set
// only on ROOT documents backing a roadmap "notion" article node; child pages
// are addressed by id inside the workspace UI. `content` is BlockNote JSON.
model Document {
  id               String   @id @default(cuid())
  slug             String?  @unique
  title            String
  authorId         String // Clerk user id
  isArchived       Boolean  @default(false)
  parentDocumentId String?
  content          String?
  coverImage       String?
  icon             String?
  isPublished      Boolean  @default(false)
  // ponytail: sibling sort key for dnd-kit reorder; drop when a fractional
  // ordering scheme is ever needed.
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentDocument Document?  @relation("DocumentChildren", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  children       Document[] @relation("DocumentChildren")

  @@index([parentDocumentId])
  @@index([isPublished])
}
