# =============================================================================
# apps/web - public frontend and Multi-Zone host (port 3000)
# =============================================================================
# Usage:
#   cp apps/web/.env.example apps/web/.env.local
#
# Fill .env.local with real values. .env.local is gitignored.
# NEXT_PUBLIC_* is exposed to the browser; never put secrets in it.
# =============================================================================

# Clerk auth
# Get both keys from: https://dashboard.clerk.com -> your app -> API Keys.
# Use the same Clerk app for web, admin, super-admin, and svc-roadmap.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/roadmaps
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/roadmaps

# Dev-only auth bypass
# Optional. Set to user, admin, or super-admin to skip real Clerk locally.
# Comment this out when you want to test real login. Ignored in production.
NEXT_PUBLIC_DEV_AUTH_ROLE=super-admin

# Multi-Zone host
# Dev host URL. Leave empty in production unless cross-zone links need an override.
NEXT_PUBLIC_HOST_URL=http://localhost:3000
# Production-only child-zone overrides. Dev defaults to localhost:3002/3003.
# ADMIN_URL=https://your-admin.vercel.app
# SUPER_ADMIN_URL=https://your-super-admin.vercel.app

# Roadmap backend
# Set this to use the real svc-roadmap backend. If empty, @workspace/core falls
# back to the local mock/localStorage roadmap service.
NEXT_PUBLIC_SVC_ROADMAP_URL=http://localhost:3005

# Sentry (optional)
# Client DSN: Sentry project -> Settings -> Client Keys (DSN). Blank disables it.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Server DSN can be the same DSN. Blank falls back to NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload at build time only. Token needs project:releases.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Notebook feature: shared kernel-server (admin editor writes, web viewer reads).
# Empty → web falls back to committed .ipynb fixtures, admin uses localStorage.
NEXT_PUBLIC_KERNEL_SERVER_URL=http://localhost:3006

# Notion workspace (read-only /notion/[slug] viewer)
# Prisma database shared with packages/db and the admin editor. Dev: SQLite —
# the relative path resolves against packages/db/prisma/, i.e. the same dev.db
# every workspace package uses. Prod: use the Postgres URL.
DATABASE_URL="file:./dev.db"
