{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "DATABASE_URL=file:./dev.db pnpm install --frozen-lockfile && pnpm -F @workspace/db generate:postgres",
  "buildCommand": "pnpm --filter svc-roadmap exec nest build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "../../node_modules/.prisma/client/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
