{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "sed -i 's|provider = \"sqlite\"|provider = \"postgresql\"|' ../../packages/db/prisma/schema.prisma && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter svc-roadmap exec nest build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "../../node_modules/.prisma/client/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
