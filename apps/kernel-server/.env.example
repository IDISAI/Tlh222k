# kernel-server (Go) — notebook CRUD + auth + CORS. Copy to .env for local dev.

PORT=3006
STORAGE_DIR=./storage/notebooks

# Dev-only auth bypass: treat every request as this role, skip JWT verification.
# MUST be empty in production. Mirrors the web apps' NEXT_PUBLIC_DEV_AUTH_ROLE.
DEV_AUTH_ROLE=super-admin

# Production auth: verify Clerk session JWTs against this JWKS endpoint (leave
# DEV_AUTH_ROLE empty to enable). Find it in the Clerk dashboard (JWKS URL).
CLERK_JWKS_URL=

# Browser origins allowed to call this server (CORS).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003
