# =============================================================================
# apps/super-admin - super-admin frontend and user management (port 3003)
# =============================================================================
# Usage:
#   cp apps/super-admin/.env.example apps/super-admin/.env.local
#
# In production this app is mounted under /super-admin by Multi-Zone. In dev it
# runs at http://localhost:3003 with no prefix.
# =============================================================================

# Clerk auth
# Get both keys from: https://dashboard.clerk.com -> your app -> API Keys.
# Use the same Clerk app as web, admin, and svc-api.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/users

# Dev-only auth bypass
# Optional. Roles: user, admin, super-admin. Comment out to test real Clerk.
# Ignored in production.
NEXT_PUBLIC_DEV_AUTH_ROLE=super-admin

# Multi-Zone
# The platform switcher points cross-zone links back to the web host.
NEXT_PUBLIC_HOST_URL=http://localhost:3000

# Backend (user management + roadmap). Empty → @workspace/core falls back to the
# local mock/localStorage service, so the user list renders empty.
# NEXT_PUBLIC_SVC_ROADMAP_URL is the legacy name, still honored as a fallback.
NEXT_PUBLIC_SVC_API_URL=http://localhost:3005

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload at build time only. Token needs project:releases.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
