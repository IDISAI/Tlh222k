# =============================================================================
# apps/admin - admin frontend and roadmap builder (port 3002)
# =============================================================================
# Usage:
#   cp apps/admin/.env.example apps/admin/.env.local
#
# In production this app is mounted under /admin by Multi-Zone. In dev it runs at
# http://localhost:3002 with no /admin prefix.
# =============================================================================

# Clerk auth
# Get both keys from: https://dashboard.clerk.com -> your app -> API Keys.
# Use the same Clerk app as web, super-admin, and svc-roadmap.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/roadmaps

# Dev-only auth bypass
# Optional. Roles: user, admin, super-admin. Comment out to test real Clerk.
# Ignored in production.
NEXT_PUBLIC_DEV_AUTH_ROLE=super-admin

# Multi-Zone
# The platform switcher points cross-zone links back to the web host.
NEXT_PUBLIC_HOST_URL=http://localhost:3000

# Roadmap backend
# Set this to use svc-roadmap. If empty, @workspace/core uses mock/localStorage.
NEXT_PUBLIC_SVC_ROADMAP_URL=http://localhost:3005

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Notebook feature: shared kernel-server for the notebook editor.
# Empty → admin editor persists to localStorage (per-browser only).
NEXT_PUBLIC_KERNEL_SERVER_URL=http://localhost:3006

# Notion workspace (/notion/[slug] editor)
# Prisma database shared with packages/db and the web viewer. Dev: SQLite —
# the relative path resolves against packages/db/prisma/. Prod: Postgres URL.
DATABASE_URL="file:./dev.db"
# Vercel Blob token for cover-image / file uploads in the Notion editor.
# Get it from: Vercel dashboard -> Storage -> Blob -> your store -> Tokens
# (or `vercel blob store add` + project env pull). Uploads fail without it.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me
